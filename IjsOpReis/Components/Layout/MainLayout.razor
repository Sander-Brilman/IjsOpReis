@inherits LayoutComponentBase
@inject AllowEditingService allowEditingService

<div class="page">

    @if (allowEditingService.IsEditingAllowed()) {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main class="content px-4">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
